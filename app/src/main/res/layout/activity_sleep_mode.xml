<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/cancel"
        app:tint="?attr/colorOnSurface" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:fontFamily="@font/ndot_57"
        android:text="@string/sleep_schedule_title"
        android:textColor="?attr/colorOnSurface"
        android:textSize="40sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.7"
        android:text="@string/sleep_schedule_desc"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardCornerRadius="28dp"
        app:strokeWidth="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/sleep_mode"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="18sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchSleepInternal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/sleep_time_section"
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/btnStartTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sleep_picker_start"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvStartTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="23:00"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnEndTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sleep_picker_end"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvEndTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/sleep_repeat_section"
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_1"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_monday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_2"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_tuesday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_3"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_wednesday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_4"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_thursday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_5"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_friday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_6"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_saturday" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/day_7"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="21dp"
            android:fontFamily="@font/ndot_57"
            android:text="@string/day_sunday" />

    </LinearLayout>

</LinearLayout>