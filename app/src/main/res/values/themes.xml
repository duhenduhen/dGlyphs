<resources>

    <style name="Base.Theme.DGlyphs" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#F2F2F2</item>
        <item name="colorPrimary">#000000</item>
        <item name="colorOnSurface">#000000</item>
        <item name="colorSurfaceVariant">#FFFFFF</item>
        <item name="colorOutline">#99000000</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.DGlyphs" parent="Base.Theme.DGlyphs" />

    <style name="TextAppearance.CollapsingHeader" parent="TextAppearance.AppCompat.Display1">
        <item name="android:fontFamily">@font/ndot_57</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.CollapsingHeaderSmall" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:fontFamily">@font/ndot_57</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

</resources>